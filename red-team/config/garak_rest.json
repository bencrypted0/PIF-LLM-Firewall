{
    "rest": {
        "RestGenerator": {
            "name": "chatbot-pif-test",
            "uri": "http://firewall:5000/chat",
            "method": "post",
            "headers": {
                "Content-Type": "application/json"
            },
            "req_template_json_object": {
                "message": "$INPUT",
                "history": [],
                "user_id": "anonymous"
            },
            "response_json": true,
            "response_json_field": "response",
            "request_timeout": 90
        }
    }
}